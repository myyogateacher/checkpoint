# Frontend
VITE_API_BASE_URL=

# Show the email/password login & signup forms. Set to "false" to offer
# Google sign-in only. Defaults to enabled when unset.
VITE_ENABLE_PASSWORD_AUTH=true

# Single-tenant lock. When set, this org is created automatically, every user
# belongs to it, and no other organizations can be created. Leave unset for
# multi-tenant mode (users create/join their own organizations).
VITE_ORG=

# Backend (stubbed — implemented later)
PORT=3001
SESSION_SECRET=change-me

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Checkpoint metadata store (where projects/migrations/audit logs live)
APP_DATABASE_URL=mysql://checkpoint:checkpoint@localhost:3306/checkpoint
